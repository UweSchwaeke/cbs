        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(cbsd_http_requests_total[5m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "cbsd-prometheus"
          },
          "legendFormat": "{{status}}"
