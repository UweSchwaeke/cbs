#
# Groups the per-host monitoring containers (Prometheus, Grafana,
# node-exporter). Start this target to bring the whole stack up, stop it to
# bring it down together. It is intentionally independent of cbsd-rs.target so
# monitoring can run (or not) regardless of the build service.

[Unit]
Description=cbsd-rs monitoring stack

[Install]
WantedBy=default.target
